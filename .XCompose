include "/usr/share/X11/locale/en_US.UTF-8/Compose"

# <Multi_key>     <1st key><2nd key><3rd key> : "Compose result"

<Multi_key>     <l><l> : "|"  U2191    # Pipe
<Multi_key>     </></> : "\"  U2191    # Pipe
<Multi_key>     <-><v> : "↓"  U2191    # Pipe
<Multi_key>     <-><^> : "↑"  U2191    # Pipe
